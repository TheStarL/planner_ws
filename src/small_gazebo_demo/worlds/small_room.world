      <link name="link">
        <collision name="collision"><geometry><box><size>0.55 1.10 0.64</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.55 1.10 0.64</size></box></geometry><material><ambient>0.20 0.55 0.25 1</ambient><diffuse>0.20 0.55 0.25 1</diffuse></material></visual>
