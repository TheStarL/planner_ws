    </model>

    <model name="west_wall">
      <static>true</static>
      <pose>-3.0 0 0.35 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.12 6.0 0.70</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.12 6.0 0.70</size></box></geometry><material><ambient>0.75 0.75 0.72 1</ambient><diffuse>0.75 0.75 0.72 1</diffuse></material></visual>
      </link>
    </model>

    <model name="center_low_box">
      <static>true</static>
      <pose>-1.25 -0.20 0.32 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.55 1.35 0.64</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.55 1.35 0.64</size></box></geometry><material><ambient>0.70 0.20 0.18 1</ambient><diffuse>0.70 0.20 0.18 1</diffuse></material></visual>
